# ─────────────────────────────────────────────────────────────────────────────
# CodeSage — Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env.local` for local development
# Copy to `.env.docker` for Docker Compose local dev
# Production: ALL secrets must live in Azure Key Vault — never in env files
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=changeme-replace-with-64-char-random-secret
ALLOWED_ORIGINS=http://localhost:3000  # prod: https://rohitganguly.dev

# ── Databases ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/codesage
ALEMBIC_DATABASE_URL=postgresql://user:pass@localhost:5432/codesage

# ── Neo4j (prod: Neo4j AuraDB — bolt+s://... URL from Aura console) ───────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Qdrant (prod: Qdrant Cloud — https://....aws.cloud.qdrant.io) ─────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=              # required for Qdrant Cloud; blank for local

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# prod: rediss://<host>:6380 (TLS — Azure Cache for Redis)

# ── Object Storage ────────────────────────────────────────────────────────────
# Local: MinIO     Prod: Azure Blob Storage (same S3-compatible endpoint)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codesage-repos

# ── LLM / Embeddings ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=          # prod: Azure Key Vault → secret: openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=              # optional fallback

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=            # prod: Azure Key Vault → secret: github-client-id
GITHUB_CLIENT_SECRET=        # prod: Azure Key Vault → secret: github-client-secret
GITHUB_PERSONAL_TOKEN=       # prod: Azure Key Vault → secret: github-pat

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_REPO_SIZE_MB=500
MAX_FILES_PER_REPO=5000
MAX_FILE_SIZE_KB=500
EMBEDDING_BATCH_SIZE=100

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000   # prod: https://api.rohitganguly.dev
NEXT_PUBLIC_WS_URL=ws://localhost:8000     # prod: wss://api.rohitganguly.dev
NEXTAUTH_SECRET=changeme-replace-with-32-char-random-secret
NEXTAUTH_URL=http://localhost:3000         # prod: https://rohitganguly.dev

# ── Azure (production only) ───────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=         # e.g. https://codesage-kv.vault.azure.net/
APPLICATIONINSIGHTS_CONNECTION_STRING=    # prod: Azure Key Vault → secret: appinsights-cs
